{
    "name": "swapi",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "check": "run-s lint typecheck type-coverage",
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "typecheck": "tsc --build --noEmit --pretty false",
        "type-coverage": "type-coverage -p ./tsconfig.app.json --at-least 100"
    },
    "dependencies": {
        "axios": "^1.16.1",
        "react": "^19.2.6",
        "react-bootstrap": "^2.10.10",
        "react-dom": "^19.2.6",
        "react-router": "^7.15.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.12.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "bootstrap": "^5.3.8",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "npm-run-all2": "^9.0.1",
        "sass": "^1.99.0",
        "type-coverage": "^2.29.7",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.12"
    }
}
